# Environment: dev | beta | docker | test
DHARMIQ_ENV=dev

# Path to repo root (auto-detected on host; set in containers)
# DHARMIQ_ROOT=/app

# Secrets
DHARMIQ_DATABASE_PASSWORD=dharmiq
DHARMIQ_JWT_SECRET=change-me-in-production
OPENROUTER_API_KEY=

# Docker / production
DHARMIQ_COST_LIMITS_ENFORCE=true

# Optional: override agent graph (enabled by default)
# DHARMIQ_AGENT_GRAPH_V2=false
# DHARMIQ_DEBUG_PROGRESS=true
