# Environment: dev | beta | prod
DHARMIQ_ENV=dev

# Path to repo root (auto-detected if unset)
# DHARMIQ_ROOT=/path/to/dharmiq

# Secrets
DHARMIQ_DATABASE_PASSWORD=dharmiq
DHARMIQ_JWT_SECRET=change-me-in-production
OPENROUTER_API_KEY=

# v0.2 agent pipeline (off in config.dev.yaml; on by default in config.beta.yaml)
DHARMIQ_AGENT_GRAPH_V2=true

# Expose debug progress events (requires superuser account)
# DHARMIQ_DEBUG_PROGRESS=true
