{
  "$schema": "dharmiq design tokens v1 — portable to CSS variables & Flutter ThemeData",
  "meta": {
    "version": "1.2.0",
    "status": "FINALIZED for v0.3",
    "themes": ["ashoka", "archival", "gazette"],
    "philosophy": "Premium SaaS restraint: border-first surfaces, sparse accent, fluid type, honest motion."
  },
  "locked": {
    "_note": "The v0.3 product ships ONLY this configuration. archival/gazette + other variants are kept for reference but are NOT shipped. See ./README.md and ./dharmiq-design-demo.html.",
    "theme": "ashoka",
    "defaultMode": "light",
    "modes": ["light", "dark"],
    "glow": "soft",
    "uiFont": "Inter",
    "displayFont": "Fraunces",
    "monoFont": "Geist Mono",
    "devanagariFont": "Noto Sans Devanagari",
    "typeScale": "XL (4K) — base 15px * 1.22",
    "hindiSize": "comfortable (size * 1.08, line-height 1.9)",
    "cursor": "system",
    "wallpaper": "aurora",
    "readingMeasure": "min(72ch, 100%) centered",
    "docPanel": "50/50 split of available space, resizable (min 300px doc / 360px chat)"
  },
  "spacing": {
    "unit": 4,
    "scale": {
      "0": 0,
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 20,
      "6": 24,
      "8": 32,
      "10": 40,
      "12": 48,
      "16": 64
    },
    "layout": {
      "chatMaxWidth": "min(72ch, 100%)",
      "contentMaxWidth": "1120px",
      "sidebarWidth": "250px",
      "sidebarCollapsedWidth": "70px"
    }
  },
  "radius": {
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },
  "motion": {
    "duration": {
      "instant": "100ms",
      "fast": "150ms",
      "normal": "220ms",
      "slow": "380ms"
    },
    "easing": {
      "default": "cubic-bezier(0.22, 1, 0.36, 1)",
      "enter": "cubic-bezier(0.16, 1, 0.3, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    },
    "reducedMotion": "respect prefers-reduced-motion"
  },
  "typography": {
    "families": {
      "sans": ["Inter", "Noto Sans Devanagari", "system-ui", "sans-serif"],
      "display": ["Fraunces", "Georgia", "serif"],
      "mono": ["Geist Mono", "ui-monospace", "monospace"],
      "devanagari": ["Noto Sans Devanagari", "Inter", "sans-serif"]
    },
    "fluid": {
      "body": "clamp(0.875rem, 0.82rem + 0.22vw, 1.0625rem)",
      "bodyLarge": "clamp(1rem, 0.95rem + 0.28vw, 1.1875rem)",
      "caption": "clamp(0.6875rem, 0.66rem + 0.12vw, 0.8125rem)",
      "heading": "clamp(1.125rem, 1rem + 0.45vw, 1.5rem)"
    },
    "lineHeight": {
      "tight": 1.35,
      "normal": 1.55,
      "relaxed": 1.7,
      "editorial": 1.75
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.04em",
      "caps": "0.06em"
    }
  },
