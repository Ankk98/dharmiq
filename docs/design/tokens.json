  "fonts4k": {
    "recommendedUi": ["Geist", "Inter"],
    "warmerUi": ["Hanken Grotesk", "Plus Jakarta Sans"],
    "displaySerif": ["Fraunces", "Newsreader"],
    "citationSerif": ["Source Serif 4", "Newsreader"],
    "mono": ["Geist Mono", "JetBrains Mono"],
    "notes": "Prefer variable fonts with optical sizing (opsz) for crisp 4K. Use clamp() fluid sizing. Enable tabular-nums for section numbers and currency.",
    "flutter": "Bundle via google_fonts or local assets; map opsz/wght axes through TextStyle.fontVariations."
  },
  "wallpapers": {
    "options": ["none", "grain", "grid", "dots", "aurora", "mesh", "topo", "chakra"],
    "darkBest": ["aurora", "mesh"],
    "lightBest": ["grain", "grid", "topo"],
    "notes": "Wallpapers sit on a low-opacity layer behind content; aurora/chakra animate slowly. Always honor prefers-reduced-motion."
  },
  "variants": {
    "ashoka-standard": { "theme": "ashoka", "fontBody": "sansDisplay", "fontHeading": "sansDisplay", "density": "normal", "lineHeight": "normal" },
    "ashoka-air": { "theme": "ashoka", "fontBody": "sans", "fontHeading": "sans", "density": "airy", "lineHeight": "relaxed", "recommended": true },
    "ashoka-dense": { "theme": "ashoka", "fontBody": "sans", "fontHeading": "sans", "density": "compact", "lineHeight": "tight" },
    "ashoka-display": { "theme": "ashoka", "fontBody": "sansDisplay", "fontHeading": "sansDisplay", "density": "display", "lineHeight": "relaxed" },
    "archival-standard": { "theme": "archival", "fontBody": "sans", "fontHeading": "serif", "density": "normal", "lineHeight": "normal" },
    "archival-editorial": { "theme": "archival", "fontBody": "editorial", "fontHeading": "serif", "density": "airy", "lineHeight": "editorial" },
    "archival-minimal": { "theme": "archival", "fontBody": "sans", "fontHeading": "sans", "density": "airy", "lineHeight": "normal", "recommended": true },
    "archival-mono": { "theme": "archival", "fontBody": "sans", "fontHeading": "serif", "density": "normal", "lineHeight": "normal", "citationMono": true },
    "gazette-standard": { "theme": "gazette", "fontBody": "serif", "fontHeading": "serifDisplay", "density": "normal", "lineHeight": "relaxed" },
    "gazette-ledger": { "theme": "gazette", "fontBody": "mono", "fontHeading": "serifDisplay", "density": "normal", "lineHeight": "normal", "ledgerLines": true },
    "gazette-modern": { "theme": "gazette", "fontBody": "sans", "fontHeading": "serifDisplay", "density": "airy", "lineHeight": "relaxed", "recommended": true },
    "gazette-warm": { "theme": "gazette", "fontBody": "serif", "fontHeading": "serifDisplay", "density": "normal", "lineHeight": "editorial", "warmShift": true }
